# OpenAI (требует VPN в РФ)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek — альтернатива без VPN (OpenAI-совместимый API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Провайдер: openai | deepseek | yandex
# Если OPENAI_API_KEY пуст, но задан DEEPSEEK_API_KEY — автоматически используется DeepSeek
LLM_PROVIDER=openai

# YandexGPT (опционально)
# LLM_PROVIDER=yandex
# YANDEX_API_KEY=
# YANDEX_FOLDER_ID=

# Настройки приложения
APP_BASE_URL=http://localhost:8501
MAX_HISTORY_ITEMS=20
MIN_TEXT_LENGTH=50

# Пути к демо-файлам (опционально)
# DEMO_VACANCY_PATH=/path/to/vacancy.docx
# DEMO_RESUME_PATH=/path/to/resume.pdf
